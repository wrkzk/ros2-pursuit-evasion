<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dd_robot">
	
	<xacro:arg name="robot_name" default="dd_robot"/>

	<!-- Base Link (Robot Body) -->
	<link name="base_link">
	  <visual>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<box size="0.5 0.5 0.25" />
			</geometry>
			<material name="blue">
				<color rgba="0 0.5 1 1"/>
			</material>
		</visual>
		<!-- Collision and Inertia -->
		<collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.5 0.5 0.25"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="5"/>
        <inertia ixx="0.13" ixy="0.0" ixz="0.0" iyy="0.21" iyz="0.0" izz="0.13"/>
      </inertial>
	</link>

	<!-- LiDAR Link -->
	<link name="laser_frame">
	  <visual>
	    <geometry>
		  <cylinder radius="0.05" length="0.04"/>
		</geometry>
		<material name="red">
		  <color rgba="1 0.2 0.2 1"/>
		</material>
	  </visual>
	  <collision> 
        <geometry>
		  <cylinder radius="0.05" length="0.04"/>
		</geometry>
	  </collision>
	  <inertial>
	    <origin xyz="0 0 0" rpy="0 0 0"/>
		<mass value="0.1"/>
		<inertia ixx="0.000075" ixy="0.0" ixz="0.0" 
               iyy="0.000075" iyz="0.0" 
               izz="0.000125" />
	  </inertial>
	</link>
	<joint name="laser_joint" type="fixed">
	  <parent link="base_link"/>
	  <child link="laser_frame"/>
	  <origin xyz="0 0 0.225" rpy="0 0 0"/>
	</joint>

	<!-- Right Wheel -->
	<link name="right_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="1.570795 0 0" />
			<geometry>
				<cylinder length="0.1" radius="0.2" />
			</geometry>
			<material name="black">
				<color rgba="0.05 0.05 0.05 1"/>
			</material>
		</visual>
		<!-- Collision and Inertia -->
		<collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0" />
      <geometry>
          <cylinder length="0.1" radius="0.2" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
    </inertial>
	</link>
	<joint name="joint_right_wheel" type="continuous">
		<parent link="base_link"/>
		<child link="right_wheel"/>
		<origin xyz="0 -0.30 0" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<!-- Left Wheel -->
	<link name="left_wheel">
		<visual>
			<origin xyz="0 0 0" rpy="1.570795 0 0" />
			<geometry>
				<cylinder length="0.1" radius="0.2" />
			</geometry>
			<material name="black">
				<color rgba="0.05 0.05 0.05 1"/>
			</material>
		</visual>
		<!-- Collision and Inertia -->
		<collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0" />
      <geometry>
          <cylinder length="0.1" radius="0.2" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
    </inertial>
	</link>
	<joint name="joint_left_wheel" type="continuous">
		<parent link="base_link"/>
		<child link="left_wheel"/>
		<origin xyz="0 0.30 0" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
	</joint>

	<!-- Rear Caster Wheel -->
	<link name="rear_caster">
		<visual>
			<origin xyz="0.0 0 0" rpy="0 0 0" />
			<geometry>
				<sphere radius="0.07" />
			</geometry>
			<material name="darkgray">
				<color rgba="0.2 0.2 0.2 1"/>
			</material>
		</visual>
		<!-- Collision and Inertia -->
		<collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.07" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
	</link>
	<joint name="joint_front_caster" type="fixed">
		<parent link="base_link"/>
		<child link="rear_caster"/>
		<origin xyz="-0.2 0 -0.125" rpy="0 0 0"/>
	</joint>

	<!-- Front Caster Wheel -->
	<link name="front_caster">
		<visual>
			<origin xyz="0.0 0 0" rpy="0 0 0" />
			<geometry>
				<sphere radius="0.07" />
			</geometry>
			<material name="darkgray">
				<color rgba="0.2 0.2 0.2 1"/>
			</material>
		</visual>
		<!-- Collision and Inertia -->
		<collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.07" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
	</link>
	<joint name="joint_rear_caster" type="fixed">
		<parent link="base_link"/>
		<child link="front_caster"/>
		<origin xyz="0.2 0 -0.125" rpy="0 0 0"/>
	</joint>

	<!-- LiDAR Sensor Definition -->
	<gazebo reference="laser_frame">
	  <sensor name="lidar" type="lidar">
	    <topic>/model/$(arg robot_name)/scan</topic>
		<update_rate>10</update_rate>
		<lidar>
		  <scan>
		    <horizontal>
			  <samples>360</samples>
			  <resolution>1</resolution>
			  <min_angle>-3.14159</min_angle>
			  <max_angle>3.14159</max_angle>
			</horizontal>
		  </scan>
		  <range>
		    <min>0.15</min>
			<max>12.0</max>
			<resolution>0.01</resolution>
		  </range>
		  <noise>
		    <type>gaussian</type>
			<mean>0.0</mean>
			<stddev>0.01</stddev>
		  </noise>
		</lidar>
		<always_on>1</always_on>
		<visualize>true</visualize>
	  </sensor>
	</gazebo>

	<!-- Communicating with Gazebo -->
	<gazebo>
		<plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
			<left_joint>joint_left_wheel</left_joint>
			<right_joint>joint_right_wheel</right_joint>
			<wheel_separation>0.6</wheel_separation>
			<wheel_radius>0.2</wheel_radius>
			<max_linear_acceleration>1.0</max_linear_acceleration>
			<odom_publish_frequency>50</odom_publish_frequency>
			
			<topic>/model/$(arg robot_name)/cmd_vel</topic>
			<odom_topic>/model/$(arg robot_name)/odometry</odom_topic>
			<tf_topic>/model/$(arg robot_name)/tf</tf_topic>
			<frame_id>$(arg robot_name)/odom</frame_id>
			<child_frame_id>$(arg robot_name)/base_link</child_frame_id>
		</plugin>
		<plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
			<joint_name>joint_left_wheel</joint_name>
			<joint_name>joint_right_wheel</joint_name>
		</plugin>
	    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
    	  	<publish_link_pose>false</publish_link_pose>
      	  	<publish_visual_pose>false</publish_visual_pose>
     	 	<publish_collision_pose>false</publish_collision_pose>
      		<publish_sensor_pose>false</publish_sensor_pose>
       	   	<publish_model_pose>true</publish_model_pose>
      		<update_frequency>10</update_frequency>
    	</plugin>
		<plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
		    <render_engine>ogre1</render_engine>
		</plugin>
	</gazebo>

	<gazebo reference="rear_caster">
		<mul1>0.0</mul1>
		<mul2>0.0</mul2>
	</gazebo>

	<gazebo reference="front_caster">
		<mul1>0.0</mul1>
		<mul2>0.0</mul2>
	</gazebo>
</robot>
